{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Sophy Communication Platform",
  "colors": {
    "primary": "#0D9373",
    "light": "#07C983",
    "dark": "#0D9373"
  },
  "favicon": "/favicon.svg",
  "openapi": "/api-reference/openapi.json",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Authentication",
            "pages": [
              "api-reference/endpoint/login",
              "api-reference/endpoint/list-tokens",
              "api-reference/endpoint/create-token"
            ]
          },
          {
            "group": "Organizations & Projects",
            "pages": [
              "api-reference/endpoint/list-organizations",
              "api-reference/endpoint/get-organization",
              "api-reference/endpoint/list-projects",
              "api-reference/endpoint/create-project",
              "api-reference/endpoint/get-project",
              "api-reference/endpoint/update-project",
              "api-reference/endpoint/delete-project"
            ]
          },
          {
            "group": "Transcripts & Dialogues",
            "pages": [
              "api-reference/endpoint/get-transcripts",
              "api-reference/endpoint/get-dialogues"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "error-handling",
              "code-examples",
              "best-practices"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://mintlify.com/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/sophy"
      },
      {
        "label": "Support",
        "href": "mailto:support@sophy.co"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Platform",
      "href": "https://platform.sophy.co"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/sophy",
      "github": "https://github.com/sophy",
      "linkedin": "https://linkedin.com/company/sophy"
    }
  }
}
