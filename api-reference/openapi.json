openapi: 3.0.3
info:
  title: Sophy Communication Platform API
  version: 1.0.0
  description: REST API for authentication, token management, and transcript/dialogue
    retrieval
paths:
  /api/auth/login/:
    post:
      operationId: auth_login_create
      description: |-
        User login endpoint. Accepts username and password.
        Returns user info and API token for subsequent requests.
      tags:
      - auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Login'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/Login'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/Login'
        required: true
      security:
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Login'
          description: ''
  /api/auth/tokens/:
    get:
      operationId: auth_tokens_list
      description: |-
        API Token management for authenticated users.
        Users can create, list, update, and delete their own tokens.
      parameters:
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      tags:
      - auth
      security:
      - tokenAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedAPITokenList'
          description: ''
    post:
      operationId: auth_tokens_create
      description: |-
        API Token management for authenticated users.
        Users can create, list, update, and delete their own tokens.
      tags:
      - auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/APIToken'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/APIToken'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/APIToken'
        required: true
      security:
      - tokenAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/APIToken'
          description: ''
  /api/auth/tokens/{id}/:
    get:
      operationId: auth_tokens_retrieve
      description: |-
        API Token management for authenticated users.
        Users can create, list, update, and delete their own tokens.
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this api token.
        required: true
      tags:
      - auth
      security:
      - tokenAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/APIToken'
          description: ''
    patch:
      operationId: auth_tokens_partial_update
      description: |-
        API Token management for authenticated users.
        Users can create, list, update, and delete their own tokens.
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this api token.
        required: true
      tags:
      - auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedAPIToken'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedAPIToken'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedAPIToken'
      security:
      - tokenAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/APIToken'
          description: ''
    delete:
      operationId: auth_tokens_destroy
      description: |-
        API Token management for authenticated users.
        Users can create, list, update, and delete their own tokens.
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this api token.
        required: true
      tags:
      - auth
      security:
      - tokenAuth: []
      responses:
        '204':
          description: No response body
  /api/schema/:
    get:
      operationId: schema_retrieve
      description: |-
        OpenApi3 schema for this API. Format can be selected via content negotiation.

        - YAML: application/vnd.oai.openapi
        - JSON: application/vnd.oai.openapi+json
      parameters:
      - in: query
        name: format
        schema:
          type: string
          enum:
          - json
          - yaml
      - in: query
        name: lang
        schema:
          type: string
          enum:
          - af
          - ar
          - ar-dz
          - ast
          - az
          - be
          - bg
          - bn
          - br
          - bs
          - ca
          - ckb
          - cs
          - cy
          - da
          - de
          - dsb
          - el
          - en
          - en-au
          - en-gb
          - eo
          - es
          - es-ar
          - es-co
          - es-mx
          - es-ni
          - es-ve
          - et
          - eu
          - fa
          - fi
          - fr
          - fy
          - ga
          - gd
          - gl
          - he
          - hi
          - hr
          - hsb
          - ht
          - hu
          - hy
          - ia
          - id
          - ig
          - io
          - is
          - it
          - ja
          - ka
          - kab
          - kk
          - km
          - kn
          - ko
          - ky
          - lb
          - lt
          - lv
          - mk
          - ml
          - mn
          - mr
          - ms
          - my
          - nb
          - ne
          - nl
          - nn
          - os
          - pa
          - pl
          - pt
          - pt-br
          - ro
          - ru
          - sk
          - sl
          - sq
          - sr
          - sr-latn
          - sv
          - sw
          - ta
          - te
          - tg
          - th
          - tk
          - tr
          - tt
          - udm
          - ug
          - uk
          - ur
          - uz
          - vi
          - zh-hans
          - zh-hant
      tags:
      - schema
      security:
      - tokenAuth: []
      - {}
      responses:
        '200':
          content:
            application/vnd.oai.openapi:
              schema:
                type: object
                additionalProperties: {}
            application/yaml:
              schema:
                type: object
                additionalProperties: {}
            application/vnd.oai.openapi+json:
              schema:
                type: object
                additionalProperties: {}
            application/json:
              schema:
                type: object
                additionalProperties: {}
          description: ''
  /api/transcripts/{project_id}/:
    get:
      operationId: transcripts_list
      description: List transcripts for a project
      parameters:
      - in: path
        name: project_id
        schema:
          type: string
          format: uuid
        description: Project ID
        required: true
      tags:
      - transcripts
      security:
      - tokenAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/Transcript'
          description: ''
  /api/transcripts/{project_id}/dialogues/:
    get:
      operationId: transcripts_dialogues_list
      description: List dialogues for a project
      parameters:
      - in: path
        name: project_id
        schema:
          type: string
          format: uuid
        description: Project ID
        required: true
      tags:
      - transcripts
      security:
      - tokenAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/Dialogue'
          description: ''
components:
  schemas:
    APIToken:
      type: object
      properties:
        id:
          type: string
          format: uuid
          readOnly: true
        token:
          type: string
          readOnly: true
        type:
          $ref: '#/components/schemas/TypeEnum'
        name:
          type: string
          description: Token name/description
          maxLength: 255
        user_id:
          type: string
          readOnly: true
        is_active:
          type: boolean
        expires_at:
          type: string
          format: date-time
          nullable: true
          description: Token expiration date. Leave blank for unlimited.
        last_used_at:
          type: string
          format: date-time
          nullable: true
        is_expired:
          type: boolean
          readOnly: true
        is_valid:
          type: boolean
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - created_at
      - id
      - is_expired
      - is_valid
      - name
      - token
      - updated_at
      - user_id
    Dialogue:
      type: object
      properties:
        _id:
          type: string
          title: ' id'
        projectID:
          type: string
        conversationID:
          type: string
        sessionID:
          type: string
        role:
          type: string
        format:
          type: string
        type:
          type: string
        message:
          type: string
          nullable: true
        input:
          type: object
          additionalProperties: {}
        payload:
          type: object
          additionalProperties: {}
        parent_message_id:
          type: string
          nullable: true
        proactive:
          type: boolean
        source:
          type: string
          nullable: true
        status:
          type: string
        startTime:
          type: string
          format: date-time
      required:
      - _id
      - conversationID
      - format
      - input
      - message
      - parent_message_id
      - payload
      - proactive
      - projectID
      - role
      - sessionID
      - source
      - startTime
      - status
      - type
    Login:
      type: object
      properties:
        username:
          type: string
          writeOnly: true
        password:
          type: string
          writeOnly: true
        token:
          type: string
          readOnly: true
        user:
          type: object
          additionalProperties: {}
          readOnly: true
      required:
      - password
      - token
      - user
      - username
    PaginatedAPITokenList:
      type: object
      required:
      - count
      - results
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=4
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=2
        results:
          type: array
          items:
            $ref: '#/components/schemas/APIToken'
    PatchedAPIToken:
      type: object
      properties:
        id:
          type: string
          format: uuid
          readOnly: true
        token:
          type: string
          readOnly: true
        type:
          $ref: '#/components/schemas/TypeEnum'
        name:
          type: string
          description: Token name/description
          maxLength: 255
        user_id:
          type: string
          readOnly: true
        is_active:
          type: boolean
        expires_at:
          type: string
          format: date-time
          nullable: true
          description: Token expiration date. Leave blank for unlimited.
        last_used_at:
          type: string
          format: date-time
          nullable: true
        is_expired:
          type: boolean
          readOnly: true
        is_valid:
          type: boolean
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
    Transcript:
      type: object
      properties:
        _id:
          type: string
          title: ' id'
        projectID:
          type: string
        conversationID:
          type: string
        sessionID:
          type: string
        reportTags:
          type: array
          items:
            type: string
        unread:
          type: boolean
        platform:
          type: string
        browser:
          type: string
        device:
          type: string
        os:
          type: string
        user:
          type: object
          additionalProperties: {}
          readOnly: true
        createdAt:
          type: string
          format: date-time
        updatedAt:
          type: string
          format: date-time
      required:
      - _id
      - browser
      - conversationID
      - createdAt
      - device
      - os
      - platform
      - projectID
      - reportTags
      - sessionID
      - unread
      - updatedAt
      - user
    TypeEnum:
      enum:
      - user
      - service
      type: string
      description: |-
        * `user` - User Token
        * `service` - Service Account Token
  securitySchemes:
    tokenAuth:
      type: http
      scheme: bearer
servers:
- url: https://platform-api.sophy.co
  description: API Server
